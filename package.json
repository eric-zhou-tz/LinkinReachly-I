{
  "name": "linkinreachly",
  "productName": "LinkinReachly",
  "version": "1.1.4",
  "description": "Template-driven LinkedIn connection outreach (desktop + Chrome extension)",
  "author": "Sentari AI <hello@linkinreachly.com>",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev --remoteDebuggingPort 9223",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sentry/electron": "^7.11.0",
    "electron-context-menu": "^4.1.2",
    "electron-log": "^5.4.3",
    "electron-unhandled": "^5.0.0",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3",
    "firebase": "^12.11.0",
    "mammoth": "^1.9.0",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@doyensec/electronegativity": "^1.10.3",
    "@electron/fuses": "^2.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/electron-window-state": "^2.0.34",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "axe-core": "^4.11.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vite": "^6.3.5",
    "vitest": "^3.0.5"
  },
  "overrides": {
    "tar": "^7.5.13",
    "@tootallnate/once": "^3.0.2"
  },
  "build": {
    "appId": "com.lireach.app",
    "productName": "LinkinReachly",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "build/icon.png",
      "build/icon.ico",
      "build/icon.svg",
      "build/icons/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "extension",
        "to": "extension",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://linkinreachly.com/downloads",
        "useMultipleRangeRequest": false
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "win": {
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "${productName}.Setup.${version}.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
