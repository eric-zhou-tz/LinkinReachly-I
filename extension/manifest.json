        "https://*.teamtailor.com/*",
        "https://*.phenom.com/*",
        "https://*.phenompeople.com/*",
        "https://*.homerun.hr/*",
        "https://*.homerun.co/*",
        "https://*.eightfold.ai/*",
        "https://*.taleo.net/*",
        "https://*.brassring.com/*",
        "https://*.successfactors.com/*",
        "https://*.dayforcehcm.com/*",
        "https://*.dayforce.com/*",
        "https://*.ultipro.com/*",
        "https://*.paylocity.com/*",
        "https://*.rippling.com/*",
        "https://*.adp.com/*",
        "https://*.comeet.co/*",
        "https://*.comeet.com/*",
        "https://*.avature.net/*",
        "https://*.jobscore.com/*",
        "https://*.freshteam.com/*",
        "https://*.polymer.co/*",
        "https://*.indeed.com/*",
        "https://*.trinethire.com/*",
        "https://*.tal.net/*",
        "https://*.oraclecloud.com/*",
        "https://*.amazon.jobs/*",
        "https://jobs.apple.com/*",
        "https://careers.google.com/*",
        "https://*.metacareers.com/*",
        "https://*.facebookcareers.com/*",
        "https://jobs.netflix.com/*",
        "https://careers.ibm.com/*",
        "https://jobs.bytedance.com/*",
        "https://*.joinhandshake.com/*",
        "https://*.welcometothejungle.com/*"
      ],
      "js": [
        "content-utils.js",
        "content-connect.js",
        "content-apply.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
