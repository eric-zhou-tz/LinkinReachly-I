{
  "manifest_version": 3,
  "name": "LinkinReachly DEV",
  "version": "1.1.4",
  "description": "[DEV BUILD] Internal development bridge for LinkinReachly — connects the desktop app to LinkedIn over a local WebSocket (127.0.0.1).",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "LinkinReachly — ON/WAIT/STOP show only on linkedin.com tabs. Click: ON ↔ STOP.",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "windows",
    "alarms",
    "debugger",
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.myworkdaysite.com/*",
    "https://jobs.ashbyhq.com/*",
    "https://*.ashbyhq.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.smrtr.io/*",
    "https://*.icims.com/*",
    "https://*.workable.com/*",
    "https://*.jobvite.com/*",
    "https://*.applytojob.com/*",
    "https://*.jazzhr.com/*",
    "https://*.recruitee.com/*",
    "https://*.bamboohr.com/*",
    "https://*.breezy.hr/*",
    "https://*.teamtailor.com/*",
    "https://*.phenom.com/*",
    "https://*.phenompeople.com/*",
    "https://*.homerun.hr/*",
    "https://*.homerun.co/*",
    "https://*.eightfold.ai/*",
    "https://*.taleo.net/*",
    "https://*.brassring.com/*",
    "https://*.successfactors.com/*",
    "https://*.dayforcehcm.com/*",
    "https://*.dayforce.com/*",
    "https://*.ultipro.com/*",
    "https://*.paylocity.com/*",
    "https://*.rippling.com/*",
    "https://*.adp.com/*",
    "https://*.comeet.co/*",
    "https://*.comeet.com/*",
    "https://*.avature.net/*",
    "https://*.jobscore.com/*",
    "https://*.freshteam.com/*",
    "https://*.polymer.co/*",
    "https://*.indeed.com/*",
    "https://*.trinethire.com/*",
    "https://*.tal.net/*",
    "https://*.oraclecloud.com/*",
    "https://*.amazon.jobs/*",
    "https://jobs.apple.com/*",
    "https://careers.google.com/*",
    "https://*.metacareers.com/*",
    "https://*.facebookcareers.com/*",
    "https://jobs.netflix.com/*",
    "https://careers.ibm.com/*",
    "https://jobs.bytedance.com/*",
    "https://*.joinhandshake.com/*",
    "https://*.welcometothejungle.com/*",
    "http://127.0.0.1:19511/*",
    "http://127.0.0.1:19512/*",
    "http://localhost:19511/*",
    "http://localhost:19512/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://*.linkedin.com/*"
      ],
      "js": [
        "shadow-forcer.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://*.linkedin.com/*",
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://*.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.lever.co/*",
        "https://*.myworkdayjobs.com/*",
